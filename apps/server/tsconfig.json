{
  "extends": "@zet-plane/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@generated/client": ["./src/prisma/gen/client/client"]
    },
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "customConditions": ["development"],
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src"]
}
