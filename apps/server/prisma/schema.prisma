generator client {
  provider        = "prisma-client"
  output          = "../src/prisma/gen/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Project {
  id          String   @id(map: "projects_pkey") @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model Node {
  id                   String                @id(map: "nodes_pkey") @default(uuid())
  projectId            String                @map("project_id")
  isProjectRoot        Boolean               @default(false) @map("is_project_root")
  isStagingRoot        Boolean               @default(false) @map("is_staging_root")
  type                 NodeType              @map("node_type")
  title                String
  description          String?
  status               NodeStatus            @default(active) @map("node_status")
  isCheckpoint         Boolean               @default(false) @map("is_checkpoint")
  checkpointResolution CheckpointResolution? @map("checkpoint_resolution")
  createdBy            CreatedBy             @map("created_by")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_nodes_project_id")
  @@map("nodes")
}

model Edge {
  id        String    @id(map: "edges_pkey") @default(uuid())
  projectId String    @map("project_id")
  fromId    String    @map("from_id")
  toId      String    @map("to_id")
  type      EdgeType  @map("edge_type")
  createdBy CreatedBy @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([fromId, toId, type], map: "uk_edges_from_to_type")
  @@index([projectId], map: "idx_edges_project_id")
  @@index([fromId], map: "idx_edges_from_id")
  @@index([toId], map: "idx_edges_to_id")
  @@map("edges")
}

enum NodeType {
  scaffold
  growth

  @@map("node_type")
}

enum NodeStatus {
  active
  blocked
  completed
  archived

  @@map("node_status")
}

enum CheckpointResolution {
  continue
  loop

  @@map("checkpoint_resolution")
}

enum EdgeType {
  composition
  dependency

  @@map("edge_type")
}

enum CreatedBy {
  human
  agent

  @@map("created_by")
}

model KnowledgeEntry {
  id              String          @id(map: "knowledge_entries_pkey") @default(uuid())
  projectId       String          @map("project_id")
  nodeId          String          @map("node_id")
  category        EntryCategory   @map("entry_category")
  title           String
  body            Json
  status          EntryStatus     @default(draft) @map("entry_status")
  embeddingStatus EmbeddingStatus @default(unindexed) @map("embedding_status")
  embedding       Unsupported("vector(1536)")?
  createdBy       CreatedBy       @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_knowledge_entries_project_id")
  @@index([nodeId], map: "idx_knowledge_entries_node_id")
  @@map("knowledge_entries")
}

model KnowledgeRevision {
  id         String    @id(map: "knowledge_revisions_pkey") @default(uuid())
  entryId    String    @map("entry_id")
  version    Int
  body       Json
  changeNote String?   @map("change_note")
  createdBy  CreatedBy @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([entryId, version], map: "uk_knowledge_revisions_entry_version")
  @@index([entryId], map: "idx_knowledge_revisions_entry_id")
  @@map("knowledge_revisions")
}

enum EntryCategory {
  decision
  pitfall
  finding
  context

  @@map("entry_category")
}

enum EntryStatus {
  draft
  published
  deprecated

  @@map("entry_status")
}

enum EmbeddingStatus {
  unindexed
  indexed

  @@map("embedding_status")
}

enum OrchestratorTaskType {
  event_anchor
  graph_growth
  checkpoint
  embedding

  @@map("orchestrator_task_type")
}

enum OrchestratorTaskStatus {
  pending
  running
  succeeded
  failed
  skipped
  waiting_for_approval

  @@map("orchestrator_task_status")
}

enum OrchestratorSourceType {
  graph_event
  knowledge_event
  schedule
  manual
  incoming_event

  @@map("orchestrator_source_type")
}

model OrchestratorTask {
  id             String                 @id(map: "orchestrator_tasks_pkey") @default(uuid())
  projectId      String                 @map("project_id")
  type           OrchestratorTaskType   @map("task_type")
  sourceType     OrchestratorSourceType @map("source_type")
  sourceId       String                 @map("source_id")
  status         OrchestratorTaskStatus @default(pending) @map("task_status")
  idempotencyKey String                 @unique(map: "uk_orchestrator_tasks_idempotency_key") @map("idempotency_key")
  input          Json
  modelResult    Json?                  @map("model_result")
  error          Json?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_orchestrator_tasks_project_id")
  @@index([status], map: "idx_orchestrator_tasks_task_status")
  @@map("orchestrator_tasks")
}

enum EventSource {
  github
  feishu
  claude_hook
  manual
  cli

  @@map("event_source")
}

enum IncomingEventStatus {
  pending
  processing
  routed
  deduplicated
  failed

  @@map("incoming_event_status")
}

model IncomingEvent {
  id             String              @id @default(uuid())
  source         EventSource
  idempotencyKey String              @unique @map("idempotency_key")
  projectId      String?             @map("project_id")
  eventType      String              @map("event_type")
  payload        Json
  status         IncomingEventStatus @default(pending)
  routedTo       String?             @map("routed_to")
  error          Json?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_incoming_events_project_id")
  @@index([status],    map: "idx_incoming_events_status")
  @@map("incoming_events")
}

model ProjectSourceMapping {
  id          String      @id @default(uuid())
  projectId   String      @map("project_id")
  source      EventSource
  sourceKey   String      @map("source_key")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@unique([source, sourceKey], map: "uk_project_source_mappings_source_key")
  @@index([projectId],          map: "idx_project_source_mappings_project_id")
  @@map("project_source_mappings")
}
