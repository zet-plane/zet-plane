{
  "name": "@zet-plane/server",
  "version": "0.0.1",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "test": "vitest run",
    "test:e2e": "vitest run --include 'test/**/*.e2e-spec.ts'",
    "test:all": "vitest run --include 'src/**/*.spec.ts' --include 'test/**/*.e2e-spec.ts'",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.13.0",
    "@zet-plane/types": "workspace:*",
    "bullmq": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@zet-plane/tsconfig": "workspace:*",
    "prisma": "^5.13.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
